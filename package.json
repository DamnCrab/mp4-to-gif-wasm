{
  "name": "mp4-to-gif-wasm",
  "version": "0.1.0",
  "description": "MP4 to GIF conversion with a bundled FFmpeg-based WebAssembly H.264 decoder and GIF pipeline.",
  "license": "LGPL-2.1-or-later",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DamnCrab/mp4-to-gif-wasm.git"
  },
  "homepage": "https://github.com/DamnCrab/mp4-to-gif-wasm#readme",
  "bugs": {
    "url": "https://github.com/DamnCrab/mp4-to-gif-wasm/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "USAGE.md",
    "KNOWN_ISSUES.md",
    "LICENSE",
    "THIRD_PARTY.md",
    "FFMPEG_COMPLIANCE.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:js && npm run size",
    "build:js": "tsc -p tsconfig.build.json && node ./scripts/prepare-dist.mjs",
    "check": "tsc --noEmit",
    "prepare:ffmpeg": "bash ./scripts/prepare-ffmpeg.sh",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.config.mjs test/unit",
    "test:integration": "vitest run --config vitest.config.mjs test/integration",
    "test:native": "vitest run --config vitest.native.config.mjs",
    "test:browser": "npm run build && node ./test/browser/build-consumers.mjs && playwright test",
    "test:browser:channels": "npm run build && node ./test/browser/build-consumers.mjs && PW_CHANNELS=1 playwright test test/browser/encode-gif.spec.js test/browser/consumer-bundlers.spec.js --project=chrome --project=chrome-beta --project=msedge",
    "test:dist": "npm run build && node ./test/package/dist-import.mjs && node ./test/package/user-flows.mjs",
    "test:coverage": "vitest run --config vitest.config.mjs --coverage",
    "test:ci": "npm run check && npm run test:coverage && npm run test:dist && npm run build:native && npm run test:native && npm run test:browser",
    "build:native": "node ./scripts/build-native.mjs",
    "size": "node ./scripts/report-size.mjs"
  },
  "keywords": [
    "gif",
    "mp4",
    "wasm",
    "ffmpeg",
    "h264"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.27.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "vue": "^3.5.31",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "mp4box": "^2.1.2"
  }
}
